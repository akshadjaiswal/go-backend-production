# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

# Server
PORT=8080
ENV=dev

# Database — replace with your local PostgreSQL details
DATABASE_URL=postgres://youruser@localhost:5432/go_backend_production_stage09?sslmode=disable

# JWT — change this to a long random string in production
JWT_SECRET=your-secret-key-change-this-to-something-long-and-random
JWT_EXPIRY_HOURS=24
