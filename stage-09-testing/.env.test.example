# Copy this file to .env.test — used ONLY by go test, never by the running server
# .env.test is gitignored — it contains your local test DB URL

# Test database — separate from the dev database
# Create it with: createdb go_backend_production_stage09_test
TEST_DATABASE_URL=postgres://youruser@localhost:5432/go_backend_production_stage09_test?sslmode=disable

# JWT secret for tests — fixed value so tests can create known tokens
JWT_SECRET=test-secret-key-for-stage09-tests
