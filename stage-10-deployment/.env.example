# .env.example — copy to .env for local development (without Docker)
#
# For Docker: don't use this file. Set vars in docker-compose.yml `environment:` block.
# For local dev: cp .env.example .env and fill in your values.
#
# .env is gitignored — never commit real secrets.

# Server
PORT=8080
ENV=dev

# Database — local PostgreSQL (not Docker)
# Create with: createdb go_backend_production_stage10
DATABASE_URL=postgres://youruser@localhost:5432/go_backend_production_stage10?sslmode=disable

# JWT — change to a long random string
# Generate: openssl rand -hex 32
JWT_SECRET=your-secret-key-change-this-to-something-long-and-random
JWT_EXPIRY_HOURS=24
